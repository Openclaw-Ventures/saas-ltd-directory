# SaaS LTD Deals — Environment Variables
# Copy to .env and fill in values

# Hugo
HUGO_VERSION=0.123.7

# Netlify (set in Netlify dashboard, not here)
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=

# Scraper config
# APPSUMO_AFFILIATE_ID=        # AppSumo affiliate partner ID
# DEALMIRROR_AFFILIATE_ID=     # DealMirror affiliate ID  
# DEALFUEL_AFFILIATE_ID=       # DealFuel affiliate ID
# DEALIFY_AFFILIATE_ID=        # Dealify affiliate ID

# AdSense (add once approved)
# ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# Monitoring (optional)
# HEALTHCHECK_URL=             # Healthcheck ping URL for cron monitoring
