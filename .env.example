# SaaS LTD Deals — Environment Variables
# Copy to .env and fill in values

# Hugo
HUGO_VERSION=0.123.7

# Netlify (set in Netlify dashboard, not here)
# NETLIFY_AUTH_TOKEN=
# NETLIFY_SITE_ID=

# Scraper config
# APPSUMO_AFFILIATE_ID=        # AppSumo affiliate partner ID
# DEALMIRROR_AFFILIATE_ID=     # DealMirror affiliate ID  
# DEALFUEL_AFFILIATE_ID=       # DealFuel affiliate ID
# DEALIFY_AFFILIATE_ID=        # Dealify affiliate ID

# AppSumo Impact.com (primary revenue) — get from Impact dashboard after approval
# APPSUMO_IMPACT_ID=placeholder_impact_id

# Direct Affiliate Programs (PartnerStack replaced — rejected 2026-03-24)
# Apply via: direct-affiliate-research.md
# monday.com — https://monday.com/affiliate-program
# MONDAY_AFFILIATE_ID=placeholder
# Brevo — https://www.brevo.com/partners/affiliates/
# BREVO_AFFILIATE_ID=placeholder
# Kit (ConvertKit) — https://kit.com/affiliate
# KIT_AFFILIATE_ID=placeholder
# Apollo.io — https://www.apollo.io/partners/affiliates
# APOLLO_AFFILIATE_ID=placeholder
# Gorgias — DEFERRED (agency-focused, reapply at 5k visitors)
# GORGIAS_AFFILIATE_ID=placeholder

# Default ref tag (used on all links until program IDs are live)
# DEFAULT_REF=saasltddir

# AdSense (add once approved)
# ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# Monitoring (optional)
# HEALTHCHECK_URL=             # Healthcheck ping URL for cron monitoring
